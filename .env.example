# ─── Supabase ───────────────────────────────────────────────
# Récupère ces valeurs dans ton projet : Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ─── Moneroo (paiement) — optionnel pour l'instant ──────────
MONEROO_WEBHOOK_SECRET=YOUR-WEBHOOK-SECRET

# ─── Pixel Facebook (suivi des campagnes Ads) — optionnel ───
# Meta Events Manager → ta source de données → ID du pixel (uniquement des chiffres)
NEXT_PUBLIC_FB_PIXEL_ID=YOUR-PIXEL-ID

# ────────────────────────────────────────────────────────────
# 1. Copie ce fichier en ".env.local"
# 2. Remplace les valeurs ci-dessus par tes vraies clés Supabase
# 3. Redémarre le serveur (npm run dev)
