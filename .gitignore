# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (contiennent des secrets : ne jamais committer)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# le modèle public reste versionné :
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
